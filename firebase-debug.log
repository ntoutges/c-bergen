[debug] [2025-12-05T17:15:13.998Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/c-bergen:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // Top-level categories\n    match /categories/{categoryId} {\n      allow read: if true; // Anyone can read this\n      allow create: if isValidCreateMetadata(); // Anyone can create a new category, assuming they adhere to the required pattern\n      allow update: if isValidUpdateMetadata() && // Ensure document is shaped properly\n        (isLocalAdmin(resource.data) || isGlobalAdmin() || (isLocalWriter(resource.data) && isOnlyModifiedChange())); // Only admins allowed to edit the category document\n\n      // Events with each category\n      match /events/{eventId} {\n        allow read: if true; // Anyone can read this\n        allow create: if isValidCreateMetadata() && // Ensure document is shaped properly\n          (isLocalWriter(get(/databases/$(database)/documents/categories/$(categoryId)).data) || isGlobalAdmin()); // Looser restrictions on how is allowed to write\n        allow update: if isValidUpdateMetadata() && // Ensure document is shaped properly\n          (isLocalWriter(get(/databases/$(database)/documents/categories/$(categoryId)).data) || isGlobalAdmin()); // Looser restrictions on how is allowed to write\n\n      }\n\n    }\n\n    // Control who is allowed to read/write the global admin document\n    match /groups/admins {\n      allow read: if true; // Anyone can read this\n      allow update: if isGlobalAdmin(); // Only admins allowed to update this document\n    }\n\n    function email() {\n      return request.auth.token.email;\n    }\n\n    // Check if admin in current document\n    function isLocalAdmin(data) {\n      return email() in data.maintainers && data.maintainers[email()] == \"admin\";\n    }\n\n    function isLocalWriter(data) {\n      return email() in data.maintainers && (data.maintainers[email()] == \"admin\" || data.maintainers[email()] == \"write\");\n    }\n\n    // Check if admin in global document\n    function isGlobalAdmin() {\n      let data = get(/databases/$(database)/documents/groups/admins).data;\n      return data != null && email() in data.maintainers && data.maintainers[email()] == \"admin\";\n    }\n\n    // Check if the only value changed is the lastModified/lastModifiedBy fields within a category document\n    function isOnlyModifiedChange() {\n      let oldData = request.resource.data;\n      let newData = resource.data;\n      return oldData.metadata == newData.metadata &&\n        oldData.maintainers == newData.maintainers &&\n        oldData.archived == newData.archived;\n    }\n\n    // Ensure that all relevant metadata + lastUpdate is both present and correct\n    function isValidCreateMetadata() {\n      let data = request.resource.data;\n      return data.metadata.createdBy == email() && // User must list themselves as the creator\n        data.metadata.createdAt != null && // Want a timestamp for when this document was created\n        (data.maintainers[email()] == \"admin\" || data.maintainers[email()] == \"write\"); // User must allow themselves to edit this document\n    }\n\n    function isValidUpdateMetadata() {\n      let oldData = request.resource.data;\n      let newData = resource.data;\n\n      return oldData.metadata == newData.metadata && // Metadata not allowed to change\n        (\n          (email() in oldData.maintainers) == (email() in newData.maintainers) || // Either user isn't maintainer\n          oldData.maintainers[email()] == newData.maintainers[email()]            // or user's maintainer status didn't change\n        ) &&\n        newData.lastModifiedBy == email() && // User must list themselves as the last modifier\n        newData.lastModified > oldData.lastModified;\n    }\n  }\n}"}]}}
